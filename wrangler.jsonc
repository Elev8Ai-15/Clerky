{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lawyrs",
  "compatibility_date": "2026-02-19",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "lawyrs-production",
      "database_id": "04174db9-6c28-49c6-9ebd-c0ce5370c54e"
    }
  ]
  // Secrets (set via: wrangler secret put ANTHROPIC_API_KEY)
  // ANTHROPIC_API_KEY — Required. Powers all AI search, research, and cross-referencing via claude-opus-4-6.
  // MEM0_API_KEY      — Optional. Enables persistent memory via Mem0 cloud.
  // COURTLISTENER_TOKEN — Optional. Legal research via CourtListener API.
  // LEX_MACHINA_CLIENT_ID / LEX_MACHINA_CLIENT_SECRET — Optional. Lex Machina analytics.
}
